local cloned = {}
local visited = {}
local bytecodeMap = {}

local function cloneInstance(instance, parent)
    if visited[instance] then return cloned[instance] end
    local newInstance = Instance.new(instance.ClassName)
    visited[instance] = true
    cloned[instance] = newInstance
    
    local success, props = pcall(instance.GetProperties, instance)
    if success and props then
        for _, prop in ipairs(props) do
            pcall(function()
                local value = instance[prop]
                if typeof(value) == "Instance" then
                    value = cloneInstance(value, newInstance)
                end
                newInstance[prop] = value
            end)
        end
    end
    
    local customProps = {"CFrame", "Size", "Position", "Orientation", "Color", "Material", 
                        "Transparency", "Reflectance", "BrickColor", "Shape", "Locked", 
                        "Anchored", "CanCollide", "Velocity", "RotVelocity", "AssemblyLinearVelocity",
                        "AssemblyAngularVelocity", "Mass", "Density", "Friction", "Elasticity",
                        "FrictionWeight", "ElasticityWeight", "NetworkOwnership"}
    if instance:IsA("BasePart") then
        for _, p in ipairs(customProps) do
            pcall(function() newInstance[p] = instance[p] end)
        end
    end
    
    if instance:IsA("MeshPart") then
        pcall(function() newInstance.MeshId = instance.MeshId end)
        pcall(function() newInstance.TextureId = instance.TextureId end)
        pcall(function() newInstance.RenderFidelity = instance.RenderFidelity end)
        pcall(function() newInstance.UVTransform = instance.UVTransform end)
        pcall(function() newInstance.VertexColor = instance.VertexColor end)
    end
    if instance:IsA("UnionOperation") then
        pcall(function() newInstance.UnionData = instance.UnionData end)
    end
    if instance:IsA("CylinderMesh") or instance:IsA("BlockMesh") or instance:IsA("SpecialMesh") then
        pcall(function() newInstance.Scale = instance.Scale end)
        pcall(function() newInstance.Offset = instance.Offset end)
        pcall(function() newInstance.MeshType = instance.MeshType end)
        if instance:IsA("SpecialMesh") then
            pcall(function() newInstance.MeshId = instance.MeshId end)
            pcall(function() newInstance.TextureId = instance.TextureId end)
        end
    end
    
    if instance:IsA("Sound") then
        local soundProps = {"SoundId", "Volume", "Pitch", "PlaybackSpeed", "Looped", 
                            "TimePosition", "TimeLength", "RollOffMaxDistance", "RollOffMinDistance",
                            "DistanceMax", "DistanceMin", "IsLoaded", "Playing", "MaxDistance"}
        for _, p in ipairs(soundProps) do
            pcall(function() newInstance[p] = instance[p] end)
        end
    end
    if instance:IsA("SoundGroup") then
        pcall(function() newInstance.Volume = instance.Volume end)
    end
    
    if instance:IsA("Script") or instance:IsA("LocalScript") or instance:IsA("ModuleScript") then
        pcall(function() newInstance.Source = instance.Source end)
        if instance:IsA("Script") then
            pcall(function() newInstance.RunContext = instance.RunContext end)
        end
        if getscriptbytecode then
            pcall(function()
                local bytecode = getscriptbytecode(instance)
                if bytecode then
                    bytecodeMap[instance:GetFullName()] = bytecode
                end
            end)
        end
        pcall(function()
            local scriptPath = workspacePath .. "scripts/" .. instance.Name:gsub("[^%w_%-]", "_") .. "_" .. timestamp .. ".lua"
            writefile(scriptPath, instance.Source)
        end)
    end
    
    for _, attrName in ipairs(instance:GetAttributes()) do
        pcall(function() newInstance:SetAttribute(attrName, instance:GetAttribute(attrName)) end)
    end
    
    for _, tag in ipairs(instance:GetTags()) do
        pcall(function() newInstance:AddTag(tag) end)
    end
    
    if instance:IsA("BasePart") then
        pcall(function() newInstance.BottomSurface = instance.BottomSurface end)
        pcall(function() newInstance.TopSurface = instance.TopSurface end)
        pcall(function() newInstance.FrontSurface = instance.FrontSurface end)
        pcall(function() newInstance.BackSurface = instance.BackSurface end)
        pcall(function() newInstance.LeftSurface = instance.LeftSurface end)
        pcall(function() newInstance.RightSurface = instance.RightSurface end)
        pcall(function() newInstance.BottomSurfaceInput = instance.BottomSurfaceInput end)
        pcall(function() newInstance.TopSurfaceInput = instance.TopSurfaceInput end)
        pcall(function() newInstance.FrontSurfaceInput = instance.FrontSurfaceInput end)
        pcall(function() newInstance.BackSurfaceInput = instance.BackSurfaceInput end)
        pcall(function() newInstance.LeftSurfaceInput = instance.LeftSurfaceInput end)
        pcall(function() newInstance.RightSurfaceInput = instance.RightSurfaceInput end)
    end
    
    if instance:IsA("Tool") then
        pcall(function() newInstance.RequiresHandle = instance.RequiresHandle end)
        pcall(function() newInstance.Grip = instance.Grip end)
        pcall(function() newInstance.GripPos = instance.GripPos end)
        pcall(function() newInstance.GripUp = instance.GripUp end)
        pcall(function() newInstance.GripForward = instance.GripForward end)
    end
    
    for _, child in ipairs(instance:GetChildren()) do
        cloneInstance(child, newInstance)
    end
    
    newInstance.Parent = parent
    return newInstance
end

