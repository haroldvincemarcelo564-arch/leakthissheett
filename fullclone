local serializedData = {}
for original, copy in pairs(cloned) do
    local fullName = pcall(original.GetFullName, original) and original:GetFullName() or tostring(original)
    local props = {}
    local success, propList = pcall(original.GetProperties, original)
    if success and propList then
        for _, prop in ipairs(propList) do
            pcall(function()
                local value = original[prop]
                if typeof(value) == "Instance" then
                    props[prop] = value:GetFullName()
                else
                    props[prop] = value
                end
            end)
        end
    end
    serializedData[fullName] = {
        ClassName = copy.ClassName,
        Properties = props,
        Children = {}
    }
    pcall(function()
        for _, child in ipairs(original:GetChildren()) do
            table.insert(serializedData[fullName].Children, child:GetFullName())
        end
    end)
end

