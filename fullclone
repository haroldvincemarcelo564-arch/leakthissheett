local globalDump = {}
pcall(function()
    local function serializeTable(t, depth, maxDepth, seen)
        depth = depth or 0
        maxDepth = maxDepth or 10
        seen = seen or {}
        if depth > maxDepth then return "[[MAX_DEPTH]]" end
        if type(t) ~= "table" then return t end
        if seen[t] then return "[[CYCLE]]" end
        seen[t] = true
        local result = {}
        for k, v in pairs(t) do
            local kStr = type(k) == "table" and "[[table]]" or tostring(k)
            local vStr = type(v) == "table" and serializeTable(v, depth+1, maxDepth, seen) or v
            result[kStr] = vStr
        end
        return result
    end
    
    globalDump._G = serializeTable(_G, 0, 15)
    
    if shared then
        globalDump.shared = serializeTable(shared, 0, 15)
    end
    
    if debug and debug.getregistry then
        pcall(function()
            local reg = debug.getregistry()
            globalDump.registry = serializeTable(reg, 0, 15)
        end)
    end
    
    if package and package.loaded then
        globalDump.loadedModules = {}
        for name, mod in pairs(package.loaded) do
            globalDump.loadedModules[name] = type(mod) == "table" and "[[table]]" or tostring(mod)
        end
    end
end)

pcall(function()
    local jsonGlobals = httpService:JSONEncode(globalDump)
    writefile(workspacePath .. "globals/globals_" .. timestamp .. ".json", jsonGlobals)
end)

local upvalueDump = {}
local metatableDump = {}

pcall(function()
    local function scanFunction(func, path)
        if type(func) ~= "function" then return end
        if debug and debug.getupvalues then
            local i = 1
            while true do
                local name, value = debug.getupvalue(func, i)
                if not name then break end
                upvalueDump[path .. "." .. name] = {
                    Name = name,
                    ValueType = type(value),
                    Value = type(value) == "table" and "[[table]]" or tostring(value)
                }
                i = i + 1
            end
        end
    end
    
    local function scanTable(t, path, depth)
        depth = depth or 0
        if depth > 5 then return end
        for k, v in pairs(t) do
            if type(v) == "function" then
                scanFunction(v, path .. "." .. tostring(k))
            elseif type(v) == "table" then
                if debug and debug.getmetatable then
                    local mt = debug.getmetatable(v)
                    if mt then
                        metatableDump[path .. "." .. tostring(k)] = {
                            Metatable = type(mt) == "table" and "[[table]]" or tostring(mt)
                        }
                    end
                end
                scanTable(v, path .. "." .. tostring(k), depth+1)
            end
        end
    end
    
    scanTable(_G, "_G", 0)
end)

pcall(function()
    writefile(workspacePath .. "upvalues/upvalues_" .. timestamp .. ".json", httpService:JSONEncode(upvalueDump))
    writefile(workspacePath .. "metatables/metatables_" .. timestamp .. ".json", httpService:JSONEncode(metatableDump))
end)

local connectionDump = {}

pcall(function()
    local function scanConnections(parent)
        for _, child in ipairs(parent:GetChildren()) do
            local className = child.ClassName
            if className:match("Event") or className:match("Remote") or className:match("Bindable") then
                if getconnections then
                    local eventNames = {"OnServerEvent", "OnClientEvent", "Event", "OnInvoke"}
                    for _, evtName in ipairs(eventNames) do
                        pcall(function()
                            local conns = getconnections(child[evtName])
                            if conns and #conns > 0 then
                                connectionDump[child:GetFullName() .. "." .. evtName] = {
                                    EventName = evtName,
                                    ConnectionCount = #conns,
                                    Connections = {}
                                }
                                for idx, conn in ipairs(conns) do
                                    connectionDump[child:GetFullName() .. "." .. evtName].Connections[idx] = {
                                        IsConnected = conn.IsConnected,
                                        IsEnabled = conn.IsEnabled,
                                        FunctionType = type(conn.Function)
                                    }
                                end
                            end
                        end)
                    end
                end
            end
            scanConnections(child)
        end
    end
    scanConnections(game)
end)

pcall(function()
    writefile(workspacePath .. "connections/connections_" .. timestamp .. ".json", httpService:JSONEncode(connectionDump))
end)

local animationData = {}
pcall(function()
    local function scanForAnimators(parent)
        for _, child in ipairs(parent:GetChildren()) do
            if child:IsA("Animator") then
                local tracks = {}
                for _, track in ipairs(child:GetPlayingAnimationTracks()) do
                    table.insert(tracks, {
                        Name = track.Name,
                        IsPlaying = track.IsPlaying,
                        Speed = track.Speed,
                        TimePosition = track.TimePosition,
                        Length = track.Length,
                        AnimationId = track.Animation and track.Animation.AnimationId or nil
