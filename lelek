-- ========== AUTO LINIS TAB ==========
local LinisTab = Window:AddTab({ Title = "Auto Linis", Icon = "broom" })

local AutoLinisRunning = false
local LinisCoroutine = nil

local function findNearestTrash()
    local char = LocalPlayer.Character
    if not char or not char:FindFirstChild("HumanoidRootPart") then return nil end
    local hrp = char.HumanoidRootPart
    local nearest, dist = nil, math.huge
    for _, obj in pairs(workspace:GetDescendants()) do
        if obj:IsA("Model") or obj:IsA("Part") then
            local name = string.lower(obj.Name)
            if name:find("trash") or name:find("garbage") or name:find("basura") or name:find("waste") or name:find("kalat") or name:find("bote") or name:find("plastic") or name:find("can") then
                local root = obj:FindFirstChild("HumanoidRootPart") or obj:FindFirstChild("RootPart") or obj:FindFirstChild("PrimaryPart") or (obj:IsA("Part") and obj)
                if root and root:IsA("BasePart") then
                    local d = (root.Position - hrp.Position).Magnitude
                    if d < dist and d < 100 then
                        dist = d
                        nearest = {object = obj, rootPart = root}
                    end
                end
            end
        end
    end
    return nearest
end

local function doPickupPrompt(trashPart)
    local humanoid = LocalPlayer.Character:FindFirstChild("Humanoid")
    if humanoid then
        local prompts = trashPart:FindFirstChild("ProximityPrompt") or trashPart:FindFirstChild("ClickDetector")
        if prompts then
            if prompts:IsA("ProximityPrompt") then
                prompts:Hold()
                wait(0.3)
                prompts:Release()
            elseif prompts:IsA("ClickDetector") then
                prompts:Click()
            end
        end
        VirtualUser:CaptureController()
        VirtualUser:ClickButton2(Vector2.new())
    end
end

LinisTab:AddToggle({
    Title = "Auto Linis (Trash Pickup)",
    Description = "Walks to nearest trash, picks up, jumps, repeats",
    Default = false,
    Callback = function(state)
        if state then
            if AutoLinisRunning then return end
            AutoLinisRunning = true
            LinisCoroutine = coroutine.create(function()
                while AutoLinisRunning do
                    local char = LocalPlayer.Character
                    if not char then wait(1) continue end
                    local hrp = char:FindFirstChild("HumanoidRootPart")
                    local hum = char:FindFirstChild("Humanoid")
                    if not hrp or not hum then wait(1) continue end

                    local trash = findNearestTrash()
                    if trash then
                        local targetPos = trash.rootPart.Position
                        hrp.CFrame = CFrame.new(hrp.Position, targetPos)
                        hrp.CFrame = hrp.CFrame + (targetPos - hrp.Position).Unit * 2
                        wait(0.1)
                        if (hrp.Position - targetPos).Magnitude < 5 then
                            doPickupPrompt(trash.object)
                            wait(0.2)
                            hum.Jump = true
                            wait(0.3)
                            hum.Jump = false
                            wait(0.2)
                        end
                    else
                        local randomDir = Vector3.new(math.random(-20,20), 0, math.random(-20,20))
                        hrp.CFrame = hrp.CFrame + randomDir
                        wait(0.5)
                    end
                    wait(0.1)
                end
            end)
            coroutine.resume(LinisCoroutine)
        else
            AutoLinisRunning = false
            LinisCoroutine = nil
        end
    end
})

LinisTab:AddButton({
    Title = "Find Trash (Highlight)",
