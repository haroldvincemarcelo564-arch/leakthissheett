-- AIMBOT - LOCKS TO HEAD
local AimbotToggle = CombatTab:AddToggle({
    Title = "Aimbot (Head Lock)",
    Description = "Locks camera to nearest player's head",
    Default = false,
    Callback = function(state)
        AimbotActive = state
        if state then
            RunService.RenderStepped:Connect(function()
                if not AimbotActive then return end
                local char = LocalPlayer.Character
                if not char or not char:FindFirstChild("HumanoidRootPart") then return end
                local nearest, dist = nil, math.huge
                for _, v in pairs(Players:GetPlayers()) do
                    if v ~= LocalPlayer and v.Character then
                        local head = v.Character:FindFirstChild("Head")
                        if head then
                            local d = (head.Position - Camera.CFrame.Position).Magnitude
                            if d < dist then
                                dist = d
                                nearest = head
                            end
                        end
                    end
                end
                if nearest then
                    Camera.CFrame = CFrame.new(Camera.CFrame.Position, nearest.Position)
                end
            end)
        end
    end
})

-- TRACERS - ADONIS "TRACK ALL" STYLE
local function createTracer(targetPart)
    local tracer = Instance.new("Part")
    tracer.Name = "Tracer"
    tracer.Size = Vector3.new(0.1, 0.1, 0.1)
    tracer.Anchored = true
    tracer.CanCollide = false
    tracer.Material = Enum.Material.Neon
    tracer.BrickColor = BrickColor.new("Bright red")
    tracer.Transparency = 0.3
    tracer.Parent = workspace

    local attachment = Instance.new("Attachment")
    attachment.Parent = tracer

    local trail = Instance.new("Trail")
    trail.Parent = tracer
    trail.Attachment0 = attachment
    trail.Color = ColorSequence.new(Color3.fromRGB(255, 0, 0))
    trail.Lifetime = 0.5
    trail.MinLength = 0.5
    trail.MaxLength = 10
    trail.Transparency = NumberSequence.new({
        NumberSequenceKeypoint.new(0, 0),
        NumberSequenceKeypoint.new(1, 1)
    })
    trail.WidthScale = NumberSequence.new(1)

    -- Update tracer position every frame to follow target
    local connection
    connection = RunService.RenderStepped:Connect(function()
        if not TracersActive or not targetPart or not targetPart.Parent then
            tracer:Destroy()
            connection:Disconnect()
            return
        end
        tracer.CFrame = targetPart.CFrame
    end)

    return tracer
end

local TracersToggle = CombatTab:AddToggle({
    Title = "Tracers (Track All)",
    Description = "Adonis-style tracers on all players",
    Default = false,
    Callback = function(state)
        TracersActive = state
        if state then
            -- Clear old tracers
            for _, obj in pairs(TracerObjects) do
                pcall(function() obj:Destroy() end)
            end
            TracerObjects = {}

            -- Create tracer for each player
            for _, v in pairs(Players:GetPlayers()) do
                if v ~= LocalPlayer and v.Character then
                    local head = v.Character:FindFirstChild("Head")
                    if head then
                        local tracer = createTracer(head)
                        table.insert(TracerObjects, tracer)
                    end
                end
            end

            -- Monitor new players
            local playerAddedConn
            playerAddedConn = Players.PlayerAdded:Connect(function(newPlayer)
                if TracersActive then
                    newPlayer.CharacterAdded:Connect(function(char)
                        wait(0.5)
                        if TracersActive and newPlayer ~= LocalPlayer then
                            local head = char:FindFirstChild("Head")
                            if head then
                                local tracer = createTracer(head)
                                table.insert(TracerObjects, tracer)
                            end
                        end
                    end)
                end
            end)

            -- Cleanup when toggled off
            TracersToggle._cleanup = function()
                playerAddedConn:Disconnect()
            end
        else
            for _, obj in pairs(TracerObjects) do
                pcall(function() obj:Destroy() end)
            end
            TracerObjects = {}
            if TracersToggle._cleanup then
                TracersToggle._cleanup()
                TracersToggle._cleanup = nil
            end
        end
    end
})

